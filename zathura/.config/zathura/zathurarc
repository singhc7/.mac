# Zathura Configuration
# Optimized for performance, efficiency, and a clean Pitch Black/Cyan aesthetic

# --- Settings ---
set scroll-step 50
set zoom-step 10
set selection-clipboard clipboard

# Rendering optimizations
set render-loading false
set database sqlite
set adjust-open width

# UI Interface
set statusbar-basename true
set window-title-basename true
set statusbar-h-padding 10
set statusbar-v-padding 10
set page-h-padding 1
set page-v-padding 1
set guioptions "" # Hide status bar and command line for a cleaner look

# Search
set incremental-search true

# --- Colors (Gruvbox Dark) ---
set default-bg                  "#1d2021"
set default-fg                  "#ebdbb2"
set statusbar-bg                "#282828"
set statusbar-fg                "#ebdbb2"
set inputbar-bg                 "#282828"
set inputbar-fg                 "#ebdbb2"

set notification-bg             "#b8bb26"
set notification-fg             "#1d2021"
set notification-error-bg       "#fb4934"
set notification-error-fg       "#1d2021"
set notification-warning-bg     "#fabd2f"
set notification-warning-fg     "#1d2021"

set highlight-color             "#b8bb26"
set highlight-active-color      "#8ec07c"

set completion-bg               "#3c3836"
set completion-fg               "#ebdbb2"
set completion-highlight-bg     "#8ec07c"
set completion-highlight-fg     "#1d2021"

set index-bg                    "#1d2021"
set index-fg                    "#ebdbb2"
set index-active-bg             "#8ec07c"
set index-active-fg             "#1d2021"

# Recolor mode (Dark Mode for documents)
set recolor                     true
set recolor-lightcolor          "#1d2021"
set recolor-darkcolor           "#ebdbb2"
set recolor-keephue             false

# --- Keybindings ---
# Navigation
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r rotate
map R reload

# Zooming
map i zoom in
map o zoom out
map + zoom in
map - zoom out
map = zoom in

# Page navigation
map [normal] <C-d> scroll half-down
map [normal] <C-u> scroll half-up

# Misc
map [normal] p print
map [normal] g goto top
