# Zathura Configuration
# Optimized for performance, efficiency, and a clean Pitch Black/Cyan aesthetic

# --- Settings ---
set scroll-step 50
set zoom-step 10
set selection-clipboard clipboard

# Rendering optimizations
set render-loading false
set database sqlite
set adjust-open width

# UI Interface
set statusbar-basename true
set window-title-basename true
set statusbar-h-padding 10
set statusbar-v-padding 10
set page-h-padding 1
set page-v-padding 1
set guioptions "" # Hide status bar and command line for a cleaner look

# Search
set incremental-search true

# --- Colors (Tokyo Night Dark) ---
set default-bg                  "#16161e"
set default-fg                  "#c0caf5"
set statusbar-bg                "#16161e"
set statusbar-fg                "#c0caf5"
set inputbar-bg                 "#16161e"
set inputbar-fg                 "#c0caf5"

set notification-bg             "#c3e88d"
set notification-fg             "#16161e"
set notification-error-bg       "#ff757f"
set notification-error-fg       "#16161e"
set notification-warning-bg     "#ffc777"
set notification-warning-fg     "#16161e"

set highlight-color             "#ffc777"
set highlight-active-color      "#c3e88d"

set completion-bg               "#283457"
set completion-fg               "#c0caf5"
set completion-highlight-bg     "#82aaff"
set completion-highlight-fg     "#16161e"

set index-bg                    "#16161e"
set index-fg                    "#c0caf5"
set index-active-bg             "#82aaff"
set index-active-fg             "#16161e"

# Recolor mode (Dark Mode for documents)
set recolor                     true
set recolor-lightcolor          "#16161e"
set recolor-darkcolor           "#c0caf5"
set recolor-keephue             false

# --- Keybindings ---
# Navigation
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r rotate
map R reload

# Zooming
map i zoom in
map o zoom out
map + zoom in
map - zoom out
map = zoom in

# Page navigation
map [normal] <C-d> scroll half-down
map [normal] <C-u> scroll half-up

# Misc
map [normal] p print
map [normal] g goto top
