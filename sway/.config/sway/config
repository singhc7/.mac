# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

# --- SSH Agent (Systemd Background Service) ---
# Use the systemd user socket for a robust, background ssh-agent.
# This eliminates race conditions and ensures the socket is always available.
exec systemctl --user start ssh-agent.socket
# We use single quotes here so that Sway does NOT try to expand $XDG_RUNTIME_DIR.
# Instead, it passes the literal string to /bin/sh, which will expand it correctly.
# This resolves the "undefined variable" warning that can cascade to line 15.
exec 'dbus-update-activation-environment --systemd SSH_AUTH_SOCK=$XDG_RUNTIME_DIR/ssh-agent.socket'
### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
# Recommends: foot
set $term foot
# Your preferred application launcher
# Note: pass the final command to swaymsg so that the resulting window can be opened
# on the original workspace that the command was run on.
# Recommends: rofi-wayland
set $rofi_cmd rofi \
        -terminal '$term'
# Shows a combined list of the applications with desktop files and
# executables from PATH.
# TODO: add window with the next release of rofi-wayland
set $menu $rofi_cmd -show combi -combi-modes drun#run -modes combi

### Performance & Behavior Optimizations
#
# Disable titlebars for better performance and screen real estate.
# 'pixel 1' is more efficient than 'normal' as it avoids rendering title text.
default_border pixel 1
default_floating_border normal

# hide_edge_borders both: Disables drawing borders on the edges of the screen.
# This reduces the number of rendering instructions per frame, saving GPU cycles.
hide_edge_borders both

# Disable gaps to reduce rendering load and maximize workspace efficiency.
# Gaps require the compositor to render parts of the background more frequently.
gaps inner 0
gaps outer 0

# Hide borders and gaps when only one window is visible on a workspace.
smart_gaps on
smart_borders on

# Disable focus_follows_mouse to reduce redraws triggered by cursor movement.
# This also prevents accidental focus stealing.
focus_follows_mouse no

# Automatically switch back and forth between workspaces when the current
# workspace number is requested.
workspace_auto_back_and_forth yes

### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
# Requires: desktop-backgrounds-compat, swaybg, jxl-pixbuf-loader
output * bg ~/Pictures/wallhaven-72rxqo.jpg fill
#
# Optimized for 120Hz display (eDP-1):
# max_render_time 1 reduces input lag by waiting until 1ms before vblank to render.
output eDP-1 {
    resolution 1920x1080@120.114Hz
    max_render_time 1
}
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

### Idle configuration
#
# --- RESOURCE OPTIMIZATION: Power Management ---
# Automatically turn off the display (DPMS) after 300 seconds (5 minutes) of inactivity.
# This reduces power consumption and GPU load during idle periods.
# 'resume' ensures the output is turned back on immediately upon user activity.
exec swayidle -w \
         timeout 300 'swaymsg "output * power off"' resume 'swaymsg "output * power on"'

# Original Example configuration (Commented out):
# exec swayidle -w \
#          timeout 300 'swaylock -f -c 000000' \
#          timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
#          before-sleep 'swaylock -f -c 000000'
#
# This will lock your screen after 300 seconds of inactivity, then turn off
# your displays after another 300 seconds, and turn your screens back on when
# resumed. It will also lock your screen before your computer goes to sleep.

### Input configuration
#
# --- PERFORMANCE OPTIMIZATION: Mouse Polling & Latency ---
# For the 120Hz display, we use a 'flat' acceleration profile.
# 1. It eliminates the CPU-intensive calculation of acceleration curves.
# 2. It provides a 1:1 movement ratio, crucial for high-refresh rate precision.
input type:pointer {
    accel_profile flat
    pointer_accel 0
}

input type:touchpad {
#       dwt enabled
       tap enabled
       natural_scroll enabled
#       middle_emulation enabled
   }
#
# You can get the names of your inputs by running: swaymsg -t get_inputs
# Read `man 5 sway-input` for more information about this section.

### Key bindings
#
# Basics:
#
    # Start a terminal
    bindsym $mod+Return exec $term

    # --- QoL: QUICK MULTIPLEXING ---
    # Launches the terminal and immediately attaches/starts a tmux session.
    # This promotes a persistent workflow where work survives terminal closures.
    bindsym $mod+Shift+Return exec $term -e tmux

    # Kill focused window
    bindsym $mod+Shift+q kill

    # Start your launcher
    bindsym $mod+d exec $menu

    # --- QoL: FASTER SWITCHING ---
    # 1. Workspace Toggle: Quickly jump back to the previous workspace.
    #    Useful for referencing documentation while coding.
    bindsym $mod+Tab workspace back_and_forth

    # 2. Window Switcher: Uses rofi to find and focus windows across all workspaces.
    #    Faster than manual navigation when many windows are open.
    bindsym $mod+q exec $rofi_cmd -show window

    # Drag floating windows by holding down $mod and left mouse button.
    # Resize them with right mouse button + $mod.
    # Despite the name, also works for non-floating windows.
    # Change normal to inverse to use left mouse button for resizing and right
    # mouse button for dragging.
    floating_modifier $mod normal

    # Reload the configuration file
    bindsym $mod+Shift+c reload

    # Exit sway (logs you out of your Wayland session)
    bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
#
# Moving around:
#
    # Move your focus around
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    # Or use $mod+[up|down|left|right]
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # Move the focused window with the same, but add Shift
    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    # Old code preserved below:
    # bindsym $mod+Shift+$right move right
    bindsym $mod+Shift+$right move right

    # Ditto, with arrow keys
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right
#
# Workspaces:
#
    # Switch to workspace
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    bindsym $mod+6 workspace number 6
    bindsym $mod+7 workspace number 7
    bindsym $mod+8 workspace number 8
    bindsym $mod+9 workspace number 9
    bindsym $mod+0 workspace number 10

    # --- QoL: CYCLIC NAVIGATION ---
    # Switch between workspaces using brackets.
    # mod+[ and mod+] for prev/next workspace.
    bindsym $mod+bracketleft workspace prev
    bindsym $mod+bracketright workspace next

    # Move containers to adjacent workspaces and follow them.
    # We use quotes here to ensure multiple commands are treated as a single binding.
    bindsym $mod+Shift+bracketleft "move container to workspace prev; workspace prev"
    bindsym $mod+Shift+bracketright "move container to workspace next; workspace next"

    # Move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    bindsym $mod+Shift+6 move container to workspace number 6
    bindsym $mod+Shift+7 move container to workspace number 7
    bindsym $mod+Shift+8 move container to workspace number 8
    bindsym $mod+Shift+9 move container to workspace number 9
    bindsym $mod+Shift+0 move container to workspace number 10
    # Note: workspaces can have any name you want, not just numbers.
    # We just use 1-10 as the default.
#
# Layout stuff:
#
    # You can "split" the current object of your focus with
    # $mod+b or $mod+v, for horizontal and vertical splits
    # respectively.
    bindsym $mod+b splith
    bindsym $mod+v splitv

    # Switch the current container between different layout styles
    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split

    # Make the current focus fullscreen
    bindsym $mod+f fullscreen

    # Toggle the current focus between tiling and floating mode
    bindsym $mod+Shift+space floating toggle

    # Swap focus between the tiling area and the floating area
    bindsym $mod+space focus mode_toggle

    # Move focus to the parent container
    bindsym $mod+a focus parent
#
# Scratchpad & Persistent Utilities:
#
    # --- QoL: SCRATCHPAD TERMINAL ---
    # A persistent, floating terminal that can be toggled from anywhere.
    # Optimized for quick tasks (package installs, git commits, etc.).
    # 'for_window' rule ensures consistent sizing and centering.
    for_window [app_id="scratch_term"] floating enable, resize set 900 600, move position center, scratchpad show
    bindsym $mod+u exec swaymsg "[app_id='scratch_term'] scratchpad show" || $term --app-id=scratch_term

    # --- QoL: TOOL INTEGRATION ---
    # Fast access to core terminal utilities without opening a full terminal first.
    bindsym $mod+n exec $term -e nnn        # File Manager
    bindsym $mod+Shift+b exec $term -e btop # System Monitor

    # Move the currently focused window to the scratchpad
    bindsym $mod+Shift+minus move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    bindsym $mod+minus scratchpad show

#
# System Controls & Portability:
#
    # --- RESOURCE MINIMALISM: Standard Tooling ---
    # These bindings use lightweight CLI tools common in minimalist setups.

    # Volume and Brightness controls removed as per user request.
    # Old bindings (commented out):
    # bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    # bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    # bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    # bindsym XF86MonBrightnessUp exec brightnessctl set +10%
    # bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

    # Screen Capture (Requires: grim, slurp, wl-copy)
    # Commented out as they may overwrite system/default bindings on your setup.
    # Print: Full screen to clipboard + notification.
    # bindsym Print exec grim - | wl-copy && notify-send 'Screenshot' 'Full screen captured'
    # Shift+Print: Select region to clipboard.
    # bindsym Shift+Print exec grim -g "$(slurp)" - | wl-copy && notify-send 'Screenshot' 'Region captured'

    # Lock Screen (Manual trigger for swaylock)
    # Changed from $mod+Shift+l to avoid collision with 'move right' (vim-style l key)
    bindsym $mod+Shift+Escape exec swaylock -c 000000
#
# Resizing containers:
#
mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    # Ditto, with arrow keys
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Include configs from 3 locations:
#  - /usr/share/sway/config.d
#  - /etc/sway/config.d
#  - $XDG_CONFIG_HOME/sway/config.d ($HOME/.config/sway/config.d)
#
# If multiple directories contain the files with the same name, the later
# directory takes precedence; `$XDG_CONFIG_HOME/sway/config.d/20-swayidle.conf`
# will always be loaded instead of `/usr/share/sway/config.d/20-swayidle.conf`
# or `/etc/sway/config.d/20-swayidle.conf`
#
# This mechanism permits overriding our default configuration per-system
# (/etc) or per-user ($XDG_CONFIG_HOME) basis. Just create the file you
# want to modify/override in the higher-level directory.
#
# For example, to disable the default bar from Fedora configs, you'll need to
#     $ echo -n > "$HOME/.config/sway/config.d/90-bar.conf"
#
# Note the quoting, the $() and the arguments quoting. All the parts are equally
# important to make the magic work. And if you want to learn the secret behind
# the trick, it's all in the `wordexp(3)`.
#
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'

### Advanced Performance Tuning
#
# --- CRITICAL PERFORMANCE OPTIMIZATION: Xwayland Removal ---
# Disabling Xwayland eliminates the entire X11 compatibility layer.
# - Saves ~50-100MB of background RAM.
# - Prevents X11-related CPU wakeups.
# - Forces all applications to use native Wayland protocols for lower latency.
# Note: This will break apps that do not support Wayland (check with 'xlsclients').
xwayland disable

# Disable mouse warping to reduce unnecessary cursor movements.
mouse_warping none

# Reduce the number of font files loaded by using a system-standard monospace.
font pango:monospace 10

# --- Tokyo Night colors for Sway ---
set $bg_color    #16161e
set $text_color  #c0caf5
set $sel_color   #283457
set $accent_color #82aaff
set $urgent_color #ff757f

# Target                 border         bg             text          indicator      child_border
client.focused           $accent_color  $accent_color  $bg_color     $accent_color  $accent_color
client.focused_inactive  $sel_color     $sel_color     $text_color   $sel_color     $sel_color
client.unfocused         $bg_color      $bg_color      $text_color   $bg_color      $bg_color
client.urgent            $urgent_color  $urgent_color  $bg_color     $urgent_color  $urgent_color
