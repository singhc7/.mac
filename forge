#!/usr/bin/env bash
set -euo pipefail

# forge — Bootstrap a fresh macOS environment from dotfiles
# Usage: forge [--dry-run]

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: forge [--dry-run]"
    echo ""
    echo "Bootstrap a fresh macOS environment from dotfiles."
    echo "Installs Homebrew packages, deploys configs via GNU Stow,"
    echo "and sets up Antidote, Borg, and Neovim."
    echo ""
    echo "Options:"
    echo "  --dry-run   Print what would be done without making changes"
    echo "  -h, --help  Show this help"
    exit 0
fi

DRY_RUN=false
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=true

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}[INFO]${NC} $*"; }
ok()    { echo -e "${GREEN}[OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*"; }

run() {
    if $DRY_RUN; then
        echo -e "${YELLOW}[DRY-RUN]${NC} $*"
    else
        "$@"
    fi
}

# ==========================================
# 1. Homebrew
# ==========================================
info "Checking for Homebrew..."
if ! command -v brew >/dev/null 2>&1; then
    info "Installing Homebrew..."
    run /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
    ok "Homebrew already installed"
fi

# ==========================================
# 2. Core Packages (via Brewfile)
# ==========================================
DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"

info "Installing Homebrew formulae from Brewfile..."
run brew bundle --file="$DOTFILES_DIR/Brewfile"

# ==========================================
# 3. GNU Stow — Deploy Dotfiles
# ==========================================

STOW_PACKAGES=(
    zsh
    git
    kitty
    nvim
    tmux
    fzf
    eza
    mpv
    aria2
    yt-dlp
    tealdeer
    scripts
    p10k
)

info "Deploying dotfiles with GNU Stow from $DOTFILES_DIR..."
for pkg in "${STOW_PACKAGES[@]}"; do
    if [[ -d "$DOTFILES_DIR/$pkg" ]]; then
        info "Stowing $pkg..."
        run stow -d "$DOTFILES_DIR" -t "$HOME" "$pkg"
        ok "$pkg deployed"
    else
        warn "Package $pkg not found in $DOTFILES_DIR, skipping"
    fi
done

# ==========================================
# 4. Zsh Plugin Manager (Antidote)
# ==========================================
info "Checking for Antidote (zsh plugin manager)..."
if [[ ! -d "$HOME/.antidote" ]]; then
    info "Installing Antidote..."
    run git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
else
    ok "Antidote already installed"
fi

# ==========================================
# 5. Borg Backup Repository
# ==========================================
BORG_REPO="$HOME/keepass-backups"
if [[ ! -d "$BORG_REPO" ]]; then
    info "Initializing Borg backup repository at $BORG_REPO..."
    run borg init --encryption=repokey "$BORG_REPO"
    ok "Borg repository initialized (save the passphrase somewhere safe!)"
else
    ok "Borg repository already exists at $BORG_REPO"
fi

# ==========================================
# 6. Neovim — Mason handles LSPs/tools
# ==========================================
info "Neovim LSP servers and tools are managed by Mason."
info "Open nvim and run :Mason to verify installed tools."

# ==========================================
# 7. Post-install
# ==========================================
echo ""
ok "Forge complete!"
info "Remaining manual steps:"
echo "  1. Set zsh as default shell:  chsh -s \$(which zsh)"
echo "  2. Open a new terminal to load all configs"
echo "  3. Run 'nvim' to trigger lazy.nvim plugin installation"
echo "  4. Run 'pre-commit install' inside the dotfiles repo"
echo "  5. Configure rclone remotes: rclone config"
