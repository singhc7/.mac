[commit]
	gpgsign = true
[user]
	signingkey = "~/.ssh/id_ed25519.pub"
	name = Chahat
	email = chahat@disroot.org
[gpg]
	format = ssh
[init]
	defaultBranch = main
[fetch]
	prune = true
[push]
	autoSetupRemote = true
	default = simple
[pull]
	rebase = true
[rebase]
	autostash = true
[core]
	editor = nvim
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
[difftool "nvimdiff"]
	cmd = nvim -d "$LOCAL" "$REMOTE"
[merge]
	tool = nvimdiff
	conflictstyle = zdiff3
[mergetool]
	prompt = false
	keepBackup = false
[mergetool "nvimdiff"]
	cmd = nvim -d "$LOCAL" "$MERGED" "$REMOTE"
[alias]
	st = status -sb
	co = checkout
	cob = checkout -b
	br = branch
	amend = commit --amend --no-edit
	undo = reset --soft HEAD~1
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	ci = commit
	unstage = restore --staged
