#!/bin/zsh

# --- AUTO-DETECT DEVICE ---
DEVICE=$(scanimage -L | grep "Canon" | sed -n "s/.*device \`\(.*\)' is .*/\1/p")

if [[ -z "$DEVICE" ]]; then
    echo "[!] Error: No Canon scanner found. Is it on?"
    exit 1
fi

TEMP_DIR=$(mktemp -d)
PAGE_NUM=1
FINAL_OUTPUT="${1:-scan_$(date +%Y%m%d_%H%M%S)}.pdf"

echo "[-] Starting Batch Scan (Resilient Mode | 300 DPI | Color)"
echo "[-] Detected Device: $DEVICE"

# --- THE LOOP ---
while true; do
    CURRENT_FILE="$TEMP_DIR/page_$(printf "%03d" $PAGE_NUM).tiff"

    echo "\n--> Scanning Page $PAGE_NUM..."

    # ATTEMPT LOOP: Try 3 times before giving up on this specific page
    SUCCESS=0
    for attempt in {1..3}; do
        # Run scanimage. If it fails, we catch the error (set +e is implied by if check)
        if scanimage --device "$DEVICE" \
            --source "Flatbed" \
            --format=tiff \
            --mode Color \
            --resolution 300 \
            -x 215.9 -y 279.4 \
            --progress \
            --output-file "$CURRENT_FILE"; then
            SUCCESS=1
            break
        else
            echo "\n[!] Scan failed (Attempt $attempt/3). Device might be busy."
            if [[ $attempt -lt 3 ]]; then
                echo "[-] Cooling down for 4 seconds..."
                sleep 4
            fi
        fi
    done

    # LOGIC: Did the page save?
    if [[ $SUCCESS -eq 1 ]]; then
        echo "[+] Page $PAGE_NUM saved."
        ((PAGE_NUM++))
    else
        echo "[!] Critical failure on Page $PAGE_NUM."
        echo "[-] Stopping scan here, but we will save previous pages."
        break
    fi

    # PROMPT
    sleep 0.5
    if ! read -q "RESPONSE?Scan another page? [y/N]: "; then
        echo
        break
    fi
    echo
done

# --- POST PROCESSING ---
# Check if at least page 001 exists
if [[ -f "$TEMP_DIR/page_001.tiff" ]]; then
    echo "\n[-] Stitching images (Lossless)..."
    img2pdf "$TEMP_DIR"/page_*.tiff --output "$TEMP_DIR/raw.pdf" --pagesize Letter

    echo "[-] Finalizing (OCR & Deskew)..."
    ocrmypdf --clean --deskew --optimize 1 "$TEMP_DIR/raw.pdf" "$FINAL_OUTPUT"

    echo "\n[DONE] Saved to: $FINAL_OUTPUT"
else
    echo "[!] No pages were successfully scanned."
fi

# Cleanup
rm -rf "$TEMP_DIR"
